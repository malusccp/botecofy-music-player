# Porta da API
PORT=4000

# String de conexão do MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/botecofy

# Origem permitida do front-end (CORS)
CLIENT_ORIGIN=http://localhost:5173

# --- Clerk (autenticação) ---
# Em produção, preencha com as chaves reais do Clerk.
# Se CLERK_SECRET_KEY ficar vazio, a API entra em MODO DEV de autenticação:
# basta enviar os headers "x-dev-user-id" e "x-dev-role" para simular um usuário.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Limite de upload de áudio (bytes) — 15 MB
MAX_AUDIO_BYTES=15728640

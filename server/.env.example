# Porta da API
PORT=4000

# String de conexão do MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/botecofy

# Origem permitida do front-end (CORS)
CLIENT_ORIGIN=http://localhost:5173

# --- Clerk (autenticação real — OBRIGATÓRIO) ---
# Pegue em https://dashboard.clerk.com → API Keys.
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# --- Resolução de papéis ---
# O papel pode vir de publicMetadata.role no Clerk (listener | curator | admin).
# Como atalho de bootstrap, e-mails listados aqui recebem o papel correspondente
# no primeiro login (útil para a demonstração sem mexer no dashboard do Clerk).
ADMIN_EMAILS=
CURATOR_EMAILS=

# Limite de upload de áudio (bytes) — 15 MB
MAX_AUDIO_BYTES=15728640
